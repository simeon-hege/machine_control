<odoo>
  <data>
    <record id="view_machine_control_cnc_device_tree" model="ir.ui.view">
      <field name="name">machine_control.cnc.device.tree</field>
      <field name="model">machine_control.cnc.device</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="host"/>
          <field name="port"/>
          <field name="last_read_at"/>
          <field name="last_status"/>
        </tree>
      </field>
    </record>

    <record id="view_machine_control_cnc_device_form" model="ir.ui.view">
      <field name="name">machine_control.cnc.device.form</field>
      <field name="model">machine_control.cnc.device</field>
      <field name="arch" type="xml">
        <form string="FANUC CNC Device">
          <header>
            <button name="action_read_position" type="object" string="Read Position Now" class="oe_highlight"/>
            <button name="action_write_macro" type="object" string="Write Macro"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="host"/>
                <field name="port"/>
                <field name="timeout"/>
                <field name="active"/>
              </group>
              <group>
                <field name="last_read_at" readonly="1"/>
                <field name="last_status" readonly="1"/>
              </group>
            </group>
            <group string="Macro Write">
              <field name="macro_no"/>
              <field name="macro_value"/>
              <field name="macro_decimals"/>
            </group>
            <notebook>
              <page string="Last Read">
                <field name="last_error" readonly="1"/>
                <field name="last_position_data" readonly="1" nolabel="1"/>
              </page>
              <page string="Snapshots">
                <field name="snapshot_ids" readonly="1">
                  <tree>
                    <field name="read_at"/>
                    <field name="status"/>
                    <field name="error_message"/>
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_machine_control_cnc_snapshot_tree" model="ir.ui.view">
      <field name="name">machine_control.cnc.snapshot.tree</field>
      <field name="model">machine_control.cnc.snapshot</field>
      <field name="arch" type="xml">
        <tree>
          <field name="read_at"/>
          <field name="device_id"/>
          <field name="status"/>
          <field name="error_message"/>
        </tree>
      </field>
    </record>

    <record id="view_machine_control_cnc_snapshot_form" model="ir.ui.view">
      <field name="name">machine_control.cnc.snapshot.form</field>
      <field name="model">machine_control.cnc.snapshot</field>
      <field name="arch" type="xml">
        <form string="CNC Snapshot">
          <sheet>
            <group>
              <field name="device_id" readonly="1"/>
              <field name="read_at" readonly="1"/>
              <field name="status" readonly="1"/>
            </group>
            <group>
              <field name="error_message" readonly="1"/>
            </group>
            <group>
              <field name="payload" readonly="1" nolabel="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_machine_control_cnc_device" model="ir.actions.act_window">
      <field name="name">CNC Devices</field>
      <field name="res_model">machine_control.cnc.device</field>
      <field name="view_mode">tree,form</field>
    </record>

    <record id="action_machine_control_cnc_snapshot" model="ir.actions.act_window">
      <field name="name">CNC Snapshots</field>
      <field name="res_model">machine_control.cnc.snapshot</field>
      <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_machine_control_root" name="Machine Control" sequence="10"/>

    <menuitem
      id="menu_machine_control_devices"
      name="CNC Devices"
      parent="menu_machine_control_root"
      action="action_machine_control_cnc_device"
      sequence="10"
    />

    <menuitem
      id="menu_machine_control_snapshots"
      name="CNC Snapshots"
      parent="menu_machine_control_root"
      action="action_machine_control_cnc_snapshot"
      sequence="20"
    />
  </data>
</odoo>